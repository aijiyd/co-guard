# Graph backend
COGUARD_GRAPH_BACKEND=neo4j

# Docker images for Neo4j deployment
NEO4J_IMAGE=neo4j:5.18.1-community
NEODASH_IMAGE=neo4jlabs/neodash:latest
NEODASH_PLATFORM=linux/amd64

# LLM backend
COGUARD_LLM_BACKEND=rule
COGUARD_LLM_BASE_URL=http://localhost:8000/v1
COGUARD_LLM_MODEL=
COGUARD_LLM_API_KEY=
COGUARD_LLM_TEMPERATURE=0.0
COGUARD_LLM_TIMEOUT_SECONDS=60.0
COGUARD_LLM_MAX_TOKENS=1024

# Semantic parsing / canonicalization
COGUARD_SCHEMA_TOP_K=3
COGUARD_SCHEMA_MATCH_THRESHOLD=0.28
COGUARD_RELATION_CLUSTER_THRESHOLD=0.62

# EDC refinement
COGUARD_REFINEMENT_ITERATIONS=1
COGUARD_REFINEMENT_RELATION_TOP_K=5

# Schema retriever
COGUARD_SCHEMA_RETRIEVER_BACKEND=vector
COGUARD_SCHEMA_RETRIEVER_MODEL=
COGUARD_SCHEMA_RETRIEVER_BASE_URL=http://localhost:8001/v1
COGUARD_SCHEMA_RETRIEVER_API_KEY=
COGUARD_SCHEMA_RETRIEVER_INSTRUCTION="Instruct: retrieve relations that are present in the given text\nQuery: {text}"

# Entity relatedness for context expansion
COGUARD_ENTITY_RELATEDNESS_THRESHOLD=0.68

# Reasoning
COGUARD_REASONING_MAX_DEPTH=3
COGUARD_REASONING_BEAM_WIDTH=3
COGUARD_REASONING_RISK_EVIDENCE_THRESHOLD=4.5
COGUARD_REASONING_BENIGN_EVIDENCE_THRESHOLD=2.4

# Context graph
COGUARD_CONTEXT_HOPS=2
COGUARD_CONTEXT_LIMIT=24

# Neo4j backend
COGUARD_NEO4J_URI=bolt://localhost:7687
COGUARD_NEO4J_USERNAME=neo4j
COGUARD_NEO4J_PASSWORD=coguard-password
COGUARD_NEO4J_DATABASE=neo4j
