GRAPH_BACKEND=memory

LLM_BACKEND=openai_compatible_local
LLM_MODEL=Qwen2.5-7B-Instruct
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL_PATH=/root/autodl-tmp/co-guard/model
LLM_DEVICE=auto
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=120.0
LLM_MAX_TOKENS=1024

LOCAL_AGENT_RUNTIME_BACKEND=
LOCAL_AGENT_MODEL_PATH=/root/autodl-tmp/co-guard/model
LOCAL_AGENT_DEFAULT_MODEL=Qwen2.5-7B-Instruct

SEMANTIC_EMBEDDING_BACKEND=vector
SCHEMA_RETRIEVER_BACKEND=vector

SCHEMA_TOP_K=3
SCHEMA_MATCH_THRESHOLD=0.28
RELATION_CLUSTER_THRESHOLD=0.62

REFINEMENT_ITERATIONS=1
REFINEMENT_RELATION_TOP_K=5

ENTITY_RELATEDNESS_THRESHOLD=0.68

REASONING_STRATEGY=hybrid
REASONING_MAX_DEPTH=3
REASONING_BEAM_WIDTH=3
REASONING_RISK_EVIDENCE_THRESHOLD=4.5
REASONING_BENIGN_EVIDENCE_THRESHOLD=2.4
REASONING_LLM_CONFIDENCE_THRESHOLD=0.7
REASONING_HYBRID_RULE_WEIGHT=0.65

CONTEXT_HOPS=2
CONTEXT_LIMIT=24
